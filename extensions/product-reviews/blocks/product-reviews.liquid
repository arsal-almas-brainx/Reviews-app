<div
  class="reviews-app"
  data-reviews-widget
  data-product-id="{{ product.id }}"
  data-proxy-path="/apps/reviews"
  {{ block.shopify_attributes }}
>
  <div class="reviews-app__header">
  {% if block.settings.heading != blank %}
    <h2 class="reviews-app__title">{{ block.settings.heading }}</h2>
  {% else %}
    <h2 class="reviews-app__title">{{ 'reviews.heading' | t }}</h2>
  {% endif %}
    <div class="reviews-app__summary" data-reviews-summary hidden>
      <span class="reviews-app__stars" data-summary-stars></span>
      <span class="reviews-app__count" data-summary-count></span>
    </div>
  </div>

  <div class="reviews-app__list" data-reviews-list>
    <p class="reviews-app__loading">Loading reviews...</p>
  </div>

  <div class="reviews-app__form-wrap">
    <h3 class="reviews-app__form-title">{{ 'reviews.write_review' | t }}</h3>
    <form class="reviews-app__form" data-review-form>
      <label class="reviews-app__label">
        {{ 'reviews.your_name' | t }}
        <input
          class="reviews-app__input"
          type="text"
          name="author_name"
          required
          maxlength="100"
          {% if customer %}
            value="{{ customer.first_name }} {{ customer.last_name }}"
          {% endif %}
        >
      </label>

      <label class="reviews-app__label">
        {{ 'reviews.rating' | t }}
        <select class="reviews-app__input" name="rating" required>
          <option value="5">5</option>
          <option value="4">4</option>
          <option value="3">3</option>
          <option value="2">2</option>
          <option value="1">1</option>
        </select>
      </label>

      <label class="reviews-app__label">
        {{ 'reviews.title' | t }}
        <input class="reviews-app__input" type="text" name="title" maxlength="200">
      </label>

      <label class="reviews-app__label">
        {{ 'reviews.review' | t }}
        <textarea
          class="reviews-app__input reviews-app__textarea"
          name="body"
          required
          minlength="3"
          maxlength="5000"
          rows="4"
        ></textarea>
      </label>

      <p class="reviews-app__message" data-form-message hidden></p>

      <button class="reviews-app__submit" type="submit" data-submit-button>
        {{ 'reviews.submit' | t }}
      </button>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Product Reviews",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "stylesheet": "reviews-widget.css",
  "javascript": "reviews-widget.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer reviews"
    }
  ]
}
{% endschema %}
